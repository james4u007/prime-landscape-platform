# Supabase (Texas Parcels project)
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-publishable-key

# Google Maps keys (client-side; restrict by HTTP referrer to the deployed domain)
NEXT_PUBLIC_GOOGLE_STATICMAPS_KEY=your-static-maps-key
NEXT_PUBLIC_GOOGLE_STREETVIEW_KEY=your-street-view-key
